datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 1. User Table (Authentication & Identity)
model User {
  id                String        @id @default(uuid())
  name              String
  email             String        @unique
  password          String
  role              String        @default("student")
  isApproved        Boolean       @default(false)
  testAttemptsLimit Int           @default(0)
  attempts          TestAttempt[] // Relation: User ne kitne tests diye
  createdAt         DateTime      @default(now())
}

// 2. Admin Table (Dedicated admin identity and access controls)
model Admin {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  secretHash  String
  secretCode  String?
  rank        String   @default("Admin")
  isFrozen    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LoginMessage {
  id              String   @id @default(uuid())
  recipientEmail  String
  recipientRole   String
  body            String   @db.Text
  senderEmail     String?
  showSenderEmail Boolean  @default(true)
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// 3. Subjects Table (e.g., Physics, Maths)
model Subject {
  id        String    @id @default(uuid())
  name      String    @unique
  chapters  Chapter[]
  createdAt DateTime  @default(now())
}

// 3. Chapters Table (e.g., Matrices, Electrostatics)
model Chapter {
  id        String     @id @default(uuid())
  name      String
  subjectId String
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
}

// 4. Questions Table
model Question {
  id            String   @id @default(uuid())
  statement     String   @db.Text
  chapterId     String
  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  options       Option[]
  correctAnswer String   // Sahi option ka text ya id
  explanation   String?  @db.Text
  createdAt     DateTime @default(now())
}

// 5. Options Table (Har question ke 4 options)
model Option {
  id         String   @id @default(uuid())
  text       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 6. Test Attempts Table (Sustained SaaS Metrics tracking ke liye)
model TestAttempt {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score      Int      // Score achieved
  totalMarks Int      // Total marks of the test
  createdAt  DateTime @default(now())
}
