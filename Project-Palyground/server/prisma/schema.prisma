datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 1. User Table (Authentication & Identity)
enum PackageType {
  STANDARD
  PREMIUM
}

model User {
  id                String        @id @default(uuid())
  name              String
  email             String        @unique
  password          String
  role              String        @default("student")
  isApproved        Boolean       @default(false)
  packageType       PackageType   @default(STANDARD)
  testAttemptsLimit Int           @default(0)
  attempts          TestAttempt[] // Relation: User ne kitne tests diye
  createdAt         DateTime      @default(now())
}

// 2. Admin Table (Dedicated admin identity and access controls)
model Admin {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  secretHash  String
  secretCode  String?
  rank        String   @default("Admin")
  isFrozen    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LoginMessage {
  id              String   @id @default(uuid())
  recipientEmail  String
  recipientRole   String
  body            String   @db.Text
  senderEmail     String?
  showSenderEmail Boolean  @default(true)
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// 3. Subjects Table (e.g., Physics, Maths)
model Subject {
  id        String    @id @default(uuid())
  name      String    @unique
  chapters  Chapter[]
  createdAt DateTime  @default(now())
}

// 3. Chapters Table (e.g., Matrices, Electrostatics)
model Chapter {
  id        String     @id @default(uuid())
  name      String
  part      String?    // e.g., "part1" or "part2"
  subjectId String
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
}

// 4. Questions Table
model Question {
  id            String   @id @default(uuid())
  statement     String   @db.Text
  chapterId     String
  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  options       Option[]
  correctAnswer String   // Sahi option ka text ya id
  explanation   String?  @db.Text
  isApproved    Boolean  @default(true) // Added for AI content review staging workflow
  isFlagged     Boolean  @default(false) // Added for AI Auditor staging workflow
  auditNotes    String?  @db.Text        // Auditor feedback notes for flagged questions
  createdAt     DateTime @default(now())
}

// 5. Options Table (Har question ke 4 options)
model Option {
  id         String   @id @default(uuid())
  text       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 6. Test Attempts Table (Sustained SaaS Metrics tracking ke liye)
model TestAttempt {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score      Float    // Score achieved (could be float due to negative marking)
  totalMarks Int      // Total marks of the test
  breakdown  Json?    // Stores the entire JSON report of the submitted test (details, cot, tips, etc.)
  createdAt  DateTime @default(now())
}

// 7. Resource Group Table
model ResourceGroup {
  id          String         @id @default(uuid())
  name        String
  description String?
  items       ResourceItem[]
  files       ResourceFile[]
  createdAt   DateTime       @default(now())
}

// 8. Resource File Table
model ResourceFile {
  id              String        @id @default(uuid())
  name            String
  type            String        // e.g., "pdf", "word", "image", "file"
  size            String
  uploadDate      String        // e.g., "2026-07-07"
  downloads       Int           @default(0)
  resourceGroupId String
  resourceGroup   ResourceGroup @relation(fields: [resourceGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

// 9. Resource Item Table
model ResourceItem {
  id              String        @id @default(uuid())
  title           String
  points          Int           @default(0)
  resourceGroupId String
  resourceGroup   ResourceGroup @relation(fields: [resourceGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}
