{
  "name": "project-palyground-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/startDev.js",
    "start": "node scripts/startProd.js",
    "dev:watch": "nodemon src/app.js",
    "db:setup": "node src/setupDatabase.js",
    "prisma:push": "prisma db push --config=./prisma.config.js",
    "prisma:migrate": "prisma migrate dev --config=./prisma.config.js",
    "prisma:deploy": "prisma migrate deploy --config=./prisma.config.js",
    "prisma:status": "prisma migrate status --config=./prisma.config.js",
    "prisma:generate": "prisma generate --config=./prisma.config.js",
    "prisma:validate": "prisma validate --config=./prisma.config.js",
    "prisma:seed": "prisma db seed --config=./prisma.config.js"
  },
  "prisma": {
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^8.8.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prisma": "^7.8.0"
  }
}
